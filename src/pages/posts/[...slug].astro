---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { config } from "virtual:nimbus/config";
import { getEntry } from "astro:content";
import { slugMap } from "../../slug-map";
import SeriesSidebar from "../../components/SeriesSidebar.astro";
import PostContent from "../../components/PostContent.astro";
import fs from "node:fs";
import path from "node:path";

export const prerender = true;

export async function getStaticPaths() {
  return Object.entries(slugMap).map(([slug, filePath]) => ({
    params: { slug },
    props: { filePath },
  }));
}

const { slug } = Astro.params;
const { filePath } = Astro.props;

const entryId = `posts/${filePath.replace(/\.mdx$/, "")}`;
const entry = await getEntry("docs", entryId);

const title = entry?.data.title ?? slug;
const description = entry?.data.description ?? "";
const markdownUrl = Astro.site ? new URL(`/posts/${slug}/index.md`, Astro.site).href : `/posts/${slug}/index.md`;
const socialImage = `/og/${entryId}.png`;

const fullPath = path.join(process.cwd(), "src/content/docs/posts", filePath);
let headings: { depth: number; slug: string; text: string }[] = [];
try {
  const raw = fs.readFileSync(fullPath, "utf-8");
  const headingRegex = /^(#{2,6})\s+(.+)$/gm;
  let match;
  while ((match = headingRegex.exec(raw)) !== null) {
    const depth = match[1].length;
    const text = match[2].trim();
    const headingSlug = text.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
    headings.push({ depth, slug: headingSlug, text });
  }
} catch {}

const pathParts = filePath.replace(/\.mdx$/, "").split("/");
const breadcrumbs = [
  { label: config.title, href: "/" },
  { label: "Posts", href: "/posts" },
  ...pathParts.slice(0, -1).map((part, i) => {
    const segmentPath = pathParts.slice(0, i + 1).join("/");
    return { label: part, href: `/posts/${segmentPath}` };
  }),
  { label: title },
];
---

<DocsLayout
  title={title}
  description={description}
  sidebar={[]}
  headings={headings}
  breadcrumbs={breadcrumbs}
  prevNext={{}}
  markdownUrl={markdownUrl}
  socialImage={socialImage}
>
  <SeriesSidebar slot="sidebar" />
  <article class="docs-content max-w-none">
    <PostContent filePath={filePath} />
  </article>
</DocsLayout>
